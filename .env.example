# =============================================================================
# Velluma — Environment Variables Reference
# =============================================================================
#
# Copy this file to .env and fill in your values.
# Never commit a .env file with real secrets to version control.
#
# Variable scoping:
#   NEXT_PUBLIC_*  — bundled into the browser (public, not secret)
#   All others     — server-side only, never exposed to the browser
#
# Quick start (local):
#   1. Start Redis:              docker-compose up -d
#   2. Copy this file:           cp .env.example .env
#   3. Fill in Supabase creds from your project dashboard
#   4. Start all services:       npm run dev
#
# =============================================================================


# =============================================================================
# SUPABASE — Required by all services
# Docs: https://supabase.com/docs/guides/getting-started
# =============================================================================

# Project URL — found in Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key — safe to expose in browser builds
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — bypasses RLS; NEVER expose to the browser
# Found in Settings > API > Project API keys
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# =============================================================================
# FRONTEND (Next.js — apps/web)
# Variables prefixed NEXT_PUBLIC_ are bundled into the client bundle.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# URL of the running API Gateway (backend BFF)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Canonical URL of this frontend deployment (used for auth callbacks, OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe publishable key — safe for client-side use
# Docs: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key


# =============================================================================
# STRIPE — Server-side keys
# Used by: api-gateway (webhooks), identity-service, invoice-payment-service
# Docs: https://dashboard.stripe.com/apikeys
# =============================================================================

# Secret key — used for all Stripe API calls server-side
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Webhook signing secret — used to verify Stripe webhook payloads
# Obtain from: Dashboard > Developers > Webhooks > signing secret
# Or via CLI:  stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret


# =============================================================================
# GOOGLE GENERATIVE AI — Contract generation
# Used by: contract-service, apps/web (API route)
# Docs: https://ai.google.dev/
# =============================================================================

# API key for Google Gemini (contract wizard AI feature)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key


# =============================================================================
# TWILIO — SMS notifications
# Used by: notification-service
# Docs: https://console.twilio.com
# =============================================================================

# Account SID — found on the Twilio Console dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth token — found on the Twilio Console dashboard
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Verified sender phone number in E.164 format (e.g. +14155552671)
TWILIO_FROM_NUMBER=+1xxxxxxxxxx


# =============================================================================
# EMAIL — Transactional email (Resend)
# Used by: notification-service
# Docs: https://resend.com/docs
# =============================================================================

# Resend API key for transactional email delivery
RESEND_API_KEY=re_your-resend-api-key

# From address used in all outgoing emails
EMAIL_FROM=noreply@velluma.com


# =============================================================================
# REDIS — Inter-service message bus
# Used by: all NestJS microservices and api-gateway
# Run locally: docker-compose up -d
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379


# =============================================================================
# API GATEWAY (apps/api-gateway)
# =============================================================================

# HTTP port the gateway listens on
PORT=3001

# Comma-separated list of allowed CORS origins.
# In development this can be a single localhost URL.
# In production, list every domain that should be permitted:
#   ALLOWED_ORIGINS=https://app.velluma.com,https://velluma.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Runtime environment — controls CORS strictness and logging verbosity
NODE_ENV=development


# =============================================================================
# WEB PUSH / VAPID — Browser push notifications
# Used by: notification-service (signing), api-gateway (exposing public key)
#
# Generate a key pair once with:
#   npx web-push generate-vapid-keys
#
# Keep VAPID_PRIVATE_KEY secret — it never leaves the server.
# VAPID_PUBLIC_KEY is safe to expose via the API and to the browser.
# =============================================================================

# Base64url-encoded VAPID public key (share with the browser)
VAPID_PUBLIC_KEY=your-vapid-public-key

# Base64url-encoded VAPID private key (server-side only — keep secret)
VAPID_PRIVATE_KEY=your-vapid-private-key

# Contact URI included in VAPID requests — use mailto: or https:
VAPID_SUBJECT=mailto:noreply@velluma.com


# =============================================================================
# HEALTH CHECK PORTS — one per microservice
# Each service exposes GET /health on this port for liveness probes.
# Default is 3100; override per-service to avoid conflicts when running locally.
# =============================================================================

# Override per service if running all services on the same host:
# HEALTH_PORT=3100   # default for all services
# For local multi-service dev, each service reads its own HEALTH_PORT from
# its own .env or from the process environment.
HEALTH_PORT=3100


# =============================================================================
# IDENTITY SERVICE extras (apps/identity-service)
# =============================================================================

# Base URL used as the return URL for Stripe Connect onboarding
APP_URL=http://localhost:3000
